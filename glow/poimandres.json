{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#e4f0fb",
    "indent": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "color": "#a6accd"
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#89ddff",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#1b1e28",
    "background_color": "#5de4c7",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "#add7ff",
    "bold": true
  },
  "h3": {
    "prefix": "### ",
    "color": "#89ddff",
    "bold": true
  },
  "h4": {
    "prefix": "#### ",
    "color": "#91b4d5"
  },
  "h5": {
    "prefix": "##### ",
    "color": "#a6accd"
  },
  "h6": {
    "prefix": "###### ",
    "color": "#5fb3a1",
    "bold": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true,
    "color": "#767c9d"
  },
  "emph": {
    "italic": true,
    "color": "#fcc5e9"
  },
  "strong": {
    "bold": true,
    "color": "#ffffff"
  },
  "hr": {
    "color": "#506477",
    "format": "\n────────\n"
  },
  "item": {
    "block_prefix": "• ",
    "color": "#5de4c7"
  },
  "enumeration": {
    "block_prefix": ". ",
    "color": "#5de4c7"
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#5de4c7",
    "underline": true
  },
  "link_text": {
    "color": "#89ddff"
  },
  "image": {
    "color": "#f087bd",
    "underline": true
  },
  "image_text": {
    "color": "#add7ff",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "color": "#5de4c7",
    "background_color": "#303340"
  },
  "code_block": {
    "color": "#e4f0fb",
    "margin": 2,
    "chroma": {
      "text": {
        "color": "#e4f0fb"
      },
      "error": {
        "color": "#ffffff",
        "background_color": "#d0679d"
      },
      "comment": {
        "color": "#767c9d"
      },
      "comment_preproc": {
        "color": "#fffac2"
      },
      "keyword": {
        "color": "#89ddff"
      },
      "keyword_reserved": {
        "color": "#fcc5e9"
      },
      "keyword_namespace": {
        "color": "#d0679d"
      },
      "keyword_type": {
        "color": "#91b4d5"
      },
      "operator": {
        "color": "#fffac2"
      },
      "punctuation": {
        "color": "#a6accd"
      },
      "name": {
        "color": "#e4f0fb"
      },
      "name_builtin": {
        "color": "#fcc5e9"
      },
      "name_tag": {
        "color": "#f087bd"
      },
      "name_attribute": {
        "color": "#89ddff"
      },
      "name_class": {
        "color": "#add7ff",
        "underline": true,
        "bold": true
      },
      "name_constant": {
        "color": "#fffac2"
      },
      "name_decorator": {
        "color": "#fffac2"
      },
      "name_exception": {
        "color": "#d0679d"
      },
      "name_function": {
        "color": "#5de4c7"
      },
      "name_other": {},
      "literal": {},
      "literal_number": {
        "color": "#f087bd"
      },
      "literal_date": {
        "color": "#91b4d5"
      },
      "literal_string": {
        "color": "#5de4c7"
      },
      "literal_string_escape": {
        "color": "#89ddff"
      },
      "generic_deleted": {
        "color": "#d0679d"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "#5de4c7"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "#89ddff"
      },
      "background": {
        "background_color": "#1b1e28"
      }
    }
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "definition_list": {},
  "definition_term": {
    "color": "#add7ff",
    "bold": true
  },
  "definition_description": {
    "block_prefix": "\n🠶 ",
    "color": "#a6accd"
  },
  "html_block": {
    "color": "#767c9d"
  },
  "html_span": {
    "color": "#767c9d"
  }
}
